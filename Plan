<script>
  // duplication du ticker pour défilement continu
  const tickerInner = document.getElementById('ticker');
  if(tickerInner) {
    const items = Array.from(tickerInner.children);
    for(let i=0; i<2; i++) {
      items.forEach(el => {
        tickerInner.appendChild(el.cloneNode(true));
      });
    }
  }
  // now playing dynamique
  const tracksList = ["Blue in Green · Miles Davis", "So What · Miles Davis", "Take Five · Dave Brubeck", "My Favorite Things · Coltrane", "Song for my Father · Horace Silver", "St. Thomas · Sonny Rollins"];
  let idx = 0;
  setInterval(() => {
    const nowDiv = document.getElementById('nowPlaying');
    if(nowDiv) {
      idx = (idx+1) % tracksList.length;
      nowDiv.innerText = "🎷 " + tracksList[idx];
    }
  }, 5800);
</script>
